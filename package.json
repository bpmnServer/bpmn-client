{
  "name": "bpmn-client",
  "version": "3.0.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "start": "node --import tsx src/cli.ts",
    "cli": "node --import tsx src/cli.ts",
    "setup": "node --import tsx src/setup.ts",
    "test": "node --import tsx ./node_modules/mocha/bin/mocha.js --config=test/.mocharc.json"
  },
  "description": "Client API for BPMN-Server webservices",
  "keywords": [
    "BPMN",
    "BPMN 2.0",
    "Workflow",
    "Node.js",
    "TypeScript"
  ],
  "author": {
    "name": "ralphhanna"
  },
  "repository": {
    "type": "git",
    "url": "git+https:github.com/ralphhanna/bpmn-client.git"
  },
  "bin": {
    "bpmn-client-setup": "./dist/setup.js",
    "bpmn-client-cli": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "axios": "^1.17.0",
    "dotenv": "^17.4.2",
    "form-data": "^4.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "chai": "^5.1.2",
    "mocha": "^11.0.0",
    "mocha-cakes-2": "^3.3.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
